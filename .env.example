# GitHub personal access token (required for --provider github, the default)
GITHUB_TOKEN=

# GitLab personal access token (required for --provider gitlab)
GITLAB_TOKEN=

# OpenRouter API key (required — used for LLM copy generation)
OPENROUTER_API_KEY=

# Google AI key (optional — used for Gemini illustration generation)
GOOGLE_AI_KEY=

# Cloudflare API token (optional — used to upload illustrations to R2)
CF_TOKEN=
